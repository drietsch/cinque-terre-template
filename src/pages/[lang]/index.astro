---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import FeaturedCarousel from '../../components/FeaturedCarousel';
import TrendingNow from '../../components/TrendingNow.astro';
import VillageSelector from '../../components/VillageSelector.astro';
import PlacesToStay from '../../components/PlacesToStay.astro';
import EatDrink from '../../components/EatDrink';
import Highlights from '../../components/Highlights';
import CuratedEscapes from '../../components/CuratedEscapes.astro';
import LatestStories from '../../components/LatestStories.astro';
import AudioGuides from '../../components/AudioGuides';
import PracticalAdvice from '../../components/PracticalAdvice';
import About from '../../components/About.astro';
import Newsletter from '../../components/Newsletter.astro';
import Footer from '../../components/Footer';
import { getPageContent, getLanguages, type Language } from '../../lib/content';

export function getStaticPaths() {
    return getLanguages().map(lang => ({
        params: { lang }
    }));
}

const { lang } = Astro.params as { lang: Language };
const page = getPageContent('home', lang);
---

<Layout title={page.meta.title} lang={lang}>
    <Hero lang={lang} />
    <FeaturedCarousel client:visible lang={lang} />
    <TrendingNow lang={lang} />
    <VillageSelector lang={lang} />
    <PlacesToStay lang={lang} />
    <EatDrink lang={lang} />
    <Highlights lang={lang} />
    <CuratedEscapes lang={lang} />
    <LatestStories lang={lang} />
    <AudioGuides lang={lang} />
    <PracticalAdvice lang={lang} />
    <About lang={lang} />
    <Newsletter lang={lang} />
    <Footer lang={lang} />
</Layout>
