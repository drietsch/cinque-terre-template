---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer';
import Newsletter from '../../components/Newsletter.astro';
import { getLanguages, getPageContent, getTeam, type Language } from '../../lib/content';

export function getStaticPaths() {
    return getLanguages().map(lang => ({
        params: { lang }
    }));
}

const { lang } = Astro.params as { lang: Language };
const page = getPageContent('home', lang);
const about = page.about;
const team = getTeam(lang);
---

<Layout title="About Us | Cinque Terre Dispatch" lang={lang}>
    <!-- Hero -->
    <section class="py-24 container mx-auto px-4">
        <div class="flex flex-col lg:flex-row items-center gap-16">
            <div class="w-full lg:w-1/2 relative">
                <div class="aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl">
                    <img src={about.image} alt={about.imageAlt} class="w-full h-full object-cover" />
                </div>
                <div class="absolute -bottom-6 -right-6 w-2/3 aspect-square bg-secondary rounded-2xl -z-10"></div>
            </div>

            <div class="w-full lg:w-1/2">
                <span class="text-sm font-semibold text-primary uppercase tracking-wider">{about.badge}</span>
                <h1 class="font-serif text-4xl md:text-5xl font-bold mt-4 mb-8 leading-tight">{about.title}</h1>
                {about.description.map((paragraph: string) => (
                    <p class="text-lg text-muted-foreground mb-6">{paragraph}</p>
                ))}

                <div class="flex items-center gap-4 pt-4">
                    <div class="w-16 h-16 rounded-full bg-gray-200 overflow-hidden">
                        <img src={team.editorInChief?.avatar} alt={team.editorInChief?.name} />
                    </div>
                    <div>
                        <p class="font-bold text-foreground text-lg">{team.editorInChief?.name}</p>
                        <p class="text-muted-foreground">{team.editorInChief?.title}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission -->
    <section class="py-24 bg-secondary/30">
        <div class="container mx-auto px-4 text-center">
            <h2 class="font-serif text-3xl md:text-4xl font-bold mb-8">Our Mission</h2>
            <p class="text-xl text-muted-foreground max-w-3xl mx-auto leading-relaxed">
                We believe travel should be more than checking off landmarks. It should be about understanding a place's soul,
                connecting with its people, and leaving with stories worth telling. Cinque Terre Dispatch is your companion
                for doing exactly that on Italy's most stunning coastline.
            </p>
        </div>
    </section>

    <!-- Values -->
    <section class="py-24 container mx-auto px-4">
        <h2 class="font-serif text-3xl md:text-4xl font-bold mb-16 text-center">What We Stand For</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="text-center">
                <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-6">
                    <span class="text-2xl">🎯</span>
                </div>
                <h3 class="font-serif text-xl font-bold mb-4">Authentic Experiences</h3>
                <p class="text-muted-foreground">
                    We go beyond tourist traps to bring you genuine local insights and hidden gems.
                </p>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-6">
                    <span class="text-2xl">🌍</span>
                </div>
                <h3 class="font-serif text-xl font-bold mb-4">Sustainable Tourism</h3>
                <p class="text-muted-foreground">
                    We promote responsible travel that respects local communities and the environment.
                </p>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-6">
                    <span class="text-2xl">✨</span>
                </div>
                <h3 class="font-serif text-xl font-bold mb-4">Editorial Excellence</h3>
                <p class="text-muted-foreground">
                    Every story is crafted with care, depth, and a passion for great storytelling.
                </p>
            </div>
        </div>
    </section>

    <Newsletter lang={lang} />
    <Footer lang={lang} />
</Layout>
