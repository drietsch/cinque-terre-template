---
import Layout from '../../../../layouts/Layout.astro';
import Footer from '../../../../components/Footer';
import { getLanguages, getVillageSlugs, getVillageBySlug, getStories, type Language } from '../../../../lib/content';

export function getStaticPaths() {
    const languages = getLanguages();
    const villageSlugs = getVillageSlugs();

    return languages.flatMap(lang =>
        villageSlugs.map(village => ({
            params: { lang, village }
        }))
    );
}

const { lang, village: villageSlug } = Astro.params as { lang: Language; village: string };
const village = getVillageBySlug(villageSlug, lang);
const allStories = getStories(lang);
// Filter stories by village (if stories have village field, otherwise show all)
const stories = allStories;

if (!village) {
    return Astro.redirect(`/${lang}/villages/`);
}
---

<Layout title={`Stories from ${village.name} | Cinque Terre Dispatch`} lang={lang} village={villageSlug}>
    <!-- Hero Section -->
    <section class="relative h-[40vh] min-h-[300px] overflow-hidden">
        <div class="absolute inset-0">
            <img
                src={village.image}
                alt={village.name}
                class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/60"></div>
        </div>

        <div class="relative h-full container mx-auto px-4 flex flex-col justify-end pb-12">
            <div class="max-w-3xl">
                <div class="inline-block px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm text-white text-xs font-bold uppercase tracking-widest mb-4">
                    The Dispatch
                </div>
                <h1 class="font-serif text-4xl md:text-6xl font-bold text-white leading-tight">
                    Stories from {village.name}
                </h1>
            </div>
        </div>
    </section>

    <!-- Stories Grid -->
    <section class="py-16 container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {stories.map((story) => (
                <article class="group cursor-pointer">
                    <div class="relative aspect-[4/3] overflow-hidden rounded-xl mb-4">
                        <img
                            src={story.image}
                            alt={story.title}
                            class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105"
                        />
                        <span class="absolute top-4 left-4 bg-white/90 text-black px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide shadow-sm">
                            {story.category}
                        </span>
                    </div>
                    <div class="space-y-3">
                        <h2 class="font-serif text-xl font-bold group-hover:text-primary transition-colors leading-tight">
                            {story.title}
                        </h2>
                        <p class="text-sm text-muted-foreground line-clamp-2">
                            {story.excerpt}
                        </p>
                        <div class="flex items-center gap-3 text-sm text-muted-foreground">
                            <div class="w-6 h-6 rounded-full bg-secondary overflow-hidden">
                                <img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${story.author}`} alt={story.author} />
                            </div>
                            <span>{story.author}</span>
                            <span>•</span>
                            <span>{story.date}</span>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </section>

    <Footer lang={lang} village={villageSlug} />
</Layout>
