---
import Layout from '../../../../layouts/Layout.astro';
import Footer from '../../../../components/Footer';
import EditorialHero from '../../../../components/EditorialHero.astro';
import EditorialIntro from '../../../../components/EditorialIntro.astro';
import ClosingNote from '../../../../components/ClosingNote.astro';
import { MapPin, Clock, Star } from 'lucide-react';
import { getLanguages, getVillageSlugs, getVillageBySlug, getExperiences, getPageContent, getItemsByVillage, type Language } from '../../../../lib/content';

export function getStaticPaths() {
    const languages = getLanguages();
    const villageSlugs = getVillageSlugs();

    return languages.flatMap(lang =>
        villageSlugs.map(village => ({
            params: { lang, village }
        }))
    );
}

const { lang, village: villageSlug } = Astro.params as { lang: Language; village: string };
const village = getVillageBySlug(villageSlug, lang);
const allExperiences = getExperiences(lang);
const experiences = getItemsByVillage(allExperiences, village?.name || '');
const page = getPageContent('thingsToDo', lang);

if (!village) {
    return Astro.redirect(`/${lang}/villages/`);
}
---

<Layout title={`Things to Do in ${village.name} | Cinque Terre Dispatch`} lang={lang} village={villageSlug}>
    <EditorialHero
        title={`Things to Do in<br/>${village.name}`}
        subtitle={page.hero.subtitle}
        badge={page.hero.badge}
        image={village.image}
    />

    <EditorialIntro
        badge={page.intro.badge}
        leadQuote={page.intro.leadQuote}
        paragraphs={page.intro.paragraphs}
    />

    <!-- Experiences List -->
    <section class="py-16 container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {experiences.length > 0 ? (
                experiences.map((experience) => (
                    <article class="group">
                        <div class="relative aspect-[4/3] overflow-hidden rounded-xl mb-6">
                            <img
                                src={experience.image}
                                alt={experience.name}
                                class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105"
                            />
                            <span class="absolute top-4 left-4 bg-white/90 text-black px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wide shadow-sm">
                                {experience.category}
                            </span>
                        </div>

                        <div class="space-y-3">
                            <h2 class="font-serif text-xl font-bold group-hover:text-primary transition-colors">
                                {experience.name}
                            </h2>
                            <p class="text-sm text-muted-foreground line-clamp-3">
                                {experience.description}
                            </p>
                            <div class="flex items-center gap-4 text-sm text-muted-foreground">
                                <span class="flex items-center gap-1">
                                    <Clock className="w-4 h-4" />
                                    {experience.duration}
                                </span>
                                <span class="flex items-center gap-1">
                                    <Star className="w-4 h-4" />
                                    {experience.difficulty}
                                </span>
                            </div>
                        </div>
                    </article>
                ))
            ) : (
                <div class="col-span-3 text-center py-16">
                    <p class="text-xl text-muted-foreground">
                        No experiences found for {village.name}. Check back soon!
                    </p>
                </div>
            )}
        </div>
    </section>

    <ClosingNote
        badge={page.closing.badge}
        title={page.closing.title}
        paragraphs={page.closing.paragraphs}
    />

    <Footer lang={lang} village={villageSlug} />
</Layout>
