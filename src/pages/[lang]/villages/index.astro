---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer';
import { getVillages, getLanguages, getCommon, type Language } from '../../../lib/content';

export function getStaticPaths() {
    return getLanguages().map(lang => ({
        params: { lang }
    }));
}

const { lang } = Astro.params as { lang: Language };
const villages = getVillages(lang);
const common = getCommon(lang);
---

<Layout title="The Five Villages | Cinque Terre Dispatch" lang={lang}>
    <!-- Hero Section -->
    <section class="relative h-[50vh] min-h-[400px] overflow-hidden">
        <div class="absolute inset-0">
            <img
                src="https://images.unsplash.com/photo-1516483638261-f4dbaf036963?q=80&w=2574&auto=format&fit=crop"
                alt="Cinque Terre Villages"
                class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/60"></div>
        </div>

        <div class="relative h-full container mx-auto px-4 flex flex-col justify-end pb-16">
            <div class="max-w-3xl">
                <div class="inline-block px-3 py-1 rounded-full bg-white/20 backdrop-blur-sm text-white text-xs font-bold uppercase tracking-widest mb-4">
                    Destinations
                </div>
                <h1 class="font-serif text-5xl md:text-7xl font-bold text-white mb-4 leading-tight">
                    The Five Villages
                </h1>
                <p class="text-white/90 text-xl font-light leading-relaxed max-w-2xl">
                    Five fishing villages clinging to the cliffs of the Italian Riviera. Each with its own character, rhythm, and secrets to discover.
                </p>
            </div>
        </div>
    </section>

    <!-- Villages Grid -->
    <section class="py-16 container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {villages.map((village, index) => (
                <a
                    href={`/${lang}/villages/${village.slug}/`}
                    class={`group relative overflow-hidden rounded-2xl aspect-[4/5] cursor-pointer ${index === 0 ? 'md:col-span-2 md:row-span-2 lg:col-span-1 lg:row-span-1' : ''}`}
                >
                    <img
                        src={village.image}
                        alt={village.name}
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>

                    <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
                        <div class="flex gap-2 mb-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            {village.tags.map(tag => (
                                <span class="text-[10px] font-bold uppercase tracking-wider bg-white/20 backdrop-blur-sm px-2 py-1 rounded-full border border-white/10">
                                    {tag}
                                </span>
                            ))}
                        </div>
                        <h2 class="font-serif text-3xl font-bold mb-2">{village.name}</h2>
                        <p class="text-sm text-white/90 mb-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            {village.description}
                        </p>
                        <span class="inline-flex items-center text-sm font-medium border-b border-white pb-0.5 opacity-0 group-hover:opacity-100 transition-all duration-300">
                            {common.buttons.exploreVillage} →
                        </span>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <Footer lang={lang} />
</Layout>
