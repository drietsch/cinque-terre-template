---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer';
import EditorialHero from '../components/EditorialHero.astro';
import EditorialIntro from '../components/EditorialIntro.astro';
import EditorNote from '../components/EditorNote.astro';
import PracticalInfoItem from '../components/PracticalInfoItem.astro';
import ReviewSummary from '../components/ReviewSummary.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ClosingNote from '../components/ClosingNote.astro';
import { Star, MapPin, Clock, Users, Sunrise, Info, Compass, Waves, Heart } from 'lucide-react';

const sights = [
    {
        id: 1,
        name: "The Harbor at Dusk",
        category: "Harbor",
        village: "Riomaggiore",
        image: "/riomaggiore_harbor_1765960456019.png",
        description: "The harbor is where Riomaggiore reveals its soul. Small boats rest in water so clear you can see the stones beneath, while the village rises in tiers of ochre, terracotta, and faded pink. As the day softens, the light turns golden, and the place feels less like a destination and more like a memory.",
        editorComment: "Visit in the late afternoon when the sun moves behind the village and the harbor falls into soft shadow. The water becomes impossibly still, and the colors deepen. Most visitors arrive midday and miss this entirely.",
        signature: "Where the village meets the sea in perfect stillness",
        bestTime: "Late afternoon to early evening",
        crowdLevel: "Moderate during day, quiet at dusk",
        duration: "30–45 minutes",
        googleRating: 4.7,
        tripadvisorRating: 4.5,
        orientation: "At sea level, 5 minutes from the station",
        access: "Steep steps down from the main street",
        seasonalNote: "Winter light is softer and more dramatic; summer brings warmth but also crowds."
    },
    {
        id: 2,
        name: "Santuario di Montenero",
        category: "Viewpoint",
        village: "Riomaggiore",
        image: "/scenic_viewpoint_1765960559207.png",
        description: "High above the village, this sanctuary offers a view that feels earned. The climb is steady but never punishing, and the reward is a panorama that stretches from the terraced vineyards to the open sea. The village below looks small and timeless, a cluster of color against the endless blue.",
        editorComment: "Go early in the morning when the air is cool and the light is clean. By midday, the heat can be intense, and the view loses its clarity. Bring water and take your time—this is not a place to rush.",
        signature: "The village seen from above, framed by sky and sea",
        bestTime: "Early morning or late afternoon",
        crowdLevel: "Quiet, rarely crowded",
        duration: "1.5–2 hours including the walk",
        googleRating: 4.8,
        tripadvisorRating: 4.7,
        orientation: "Above the village, 30-minute uphill walk from Piazza Vignaioli",
        access: "Well-maintained mule track, some steep sections",
        seasonalNote: "Spring and autumn offer the best light and temperature for the climb."
    },
    {
        id: 3,
        name: "Castello di Riomaggiore",
        category: "Cultural Site",
        village: "Riomaggiore",
        image: "/historic_church_1765960706254.png",
        description: "Built in 1260, the castle sits at the highest point of the village, a stone sentinel that has watched over Riomaggiore for centuries. Its walls are thick and weathered, and from its terraces, the view extends in every direction—sea, village, hills. It is a place that speaks of defense and endurance.",
        editorComment: "Visit in the late afternoon when the sun is low and the stone glows warm. The interior now serves as a cultural center, but the terraces are the real draw. Bring a camera, but also take time to simply stand and look.",
        signature: "A fortress with a view that commands the coast",
        bestTime: "Late afternoon for golden light",
        crowdLevel: "Moderate",
        duration: "30–40 minutes",
        googleRating: 4.5,
        tripadvisorRating: 4.4,
        orientation: "At the highest point of town, 10-minute uphill walk",
        access: "Stone steps, moderately steep",
        seasonalNote: "Open seasonally; check hours before visiting."
    },
    {
        id: 4,
        name: "San Giovanni Battista",
        category: "Cultural Site",
        village: "Riomaggiore",
        image: "/historic_church_1765960706254.png",
        description: "Founded in 1340, this Gothic church stands at the heart of the village, its neo-Gothic facade and striking rose window weathered by centuries of salt air. Inside, the space is cool and quiet, a refuge from the heat and noise of the streets. The light filters through stained glass, and time seems to slow.",
        editorComment: "Step inside during the midday heat when the village is at its busiest. The contrast is immediate—outside, everything is bright and loud; inside, everything is still. It's a moment of pause that feels necessary.",
        signature: "A place of quiet in the center of everything",
        bestTime: "Midday for the interior light",
        crowdLevel: "Quiet, rarely crowded",
        duration: "15–20 minutes",
        googleRating: 4.6,
        tripadvisorRating: 4.5,
        orientation: "Central village, near the main piazza",
        access: "Easy access from main street",
        seasonalNote: "Open year-round; most atmospheric in winter when the village is quiet."
    },
    {
        id: 5,
        name: "Via dell'Amore Trailhead",
        category: "Trail",
        village: "Riomaggiore",
        image: "/scenic_viewpoint_1765960559207.png",
        description: "Though the famous Love Path to Manarola has been closed for repairs, the trailhead remains a place of pilgrimage. Visitors come to see where the legendary coastal walk once began, to imagine the path carved into the cliffs, and to hope for its eventual reopening. Even in its absence, the romance of it lingers.",
        editorComment: "The view from the trailhead is still worth the visit. Look south along the coast and you'll see the path suspended between land and sea. It's a reminder of what once was and what may be again. Check for reopening updates before your visit.",
        signature: "A trail remembered, a view that remains",
        bestTime: "Late afternoon for the best coastal light",
        crowdLevel: "Moderate, popular photo spot",
        duration: "10–15 minutes",
        googleRating: 4.3,
        tripadvisorRating: 4.2,
        orientation: "South of the village, near the marina",
        access: "Easy walk from the station",
        seasonalNote: "Check official Cinque Terre website for reopening updates."
    },
    {
        id: 6,
        name: "Spiaggia di Riomaggiore",
        category: "Beach",
        village: "Riomaggiore",
        image: "/beach_cove_1765960653545.png",
        description: "This small, pebbly beach near the marina is not a place for sunbathing crowds. It is a sheltered cove where the water is startlingly clear and the atmosphere is unhurried. Locals come here to swim in the early morning or late afternoon, and there is a quiet understanding that this place is for those who know.",
        editorComment: "The water is cold even in summer, but refreshing in the best way. Arrive before 9 AM or after 5 PM to have it mostly to yourself. The cove is sheltered from wind, making it ideal even on breezy days.",
        signature: "A hidden cove where the village comes to swim",
        bestTime: "Early morning or late afternoon",
        crowdLevel: "Very quiet, mostly locals",
        duration: "1–2 hours",
        googleRating: 4.4,
        tripadvisorRating: 4.3,
        orientation: "Near the marina, 3 minutes from the harbor",
        access: "Rocky beach, water shoes recommended",
        seasonalNote: "Best from May to September when the water is swimmable."
    },
    {
        id: 7,
        name: "Via Colombo",
        category: "Street",
        village: "Riomaggiore",
        image: "/riomaggiore_harbor_1765960456019.png",
        description: "Riomaggiore's main street is the village's beating heart. Lined with restaurants, wine bars, and small shops, it pulses with life from morning until late evening. The street follows the natural contour of the valley, connecting the station to the harbor, and offers glimpses of daily life that feel authentic and unperformed.",
        editorComment: "Walk it slowly in the early evening when locals emerge for their passeggiata. The energy shifts from tourist-focused to genuinely local, and you'll see the village as it sees itself. Stop for an aperitivo at one of the wine bars.",
        signature: "The artery of village life, morning to night",
        bestTime: "Early evening for the passeggiata",
        crowdLevel: "Busy throughout the day",
        duration: "20–30 minutes to walk, longer to linger",
        googleRating: 4.6,
        tripadvisorRating: 4.5,
        orientation: "Main street from station to harbor",
        access: "Paved, some steps, wheelchair accessible in sections",
        seasonalNote: "Liveliest in summer evenings; quieter but charming in winter."
    },
    {
        id: 8,
        name: "Oratorio di Santa Maria Assunta",
        category: "Cultural Site",
        village: "Riomaggiore",
        image: "/historic_church_1765960706254.png",
        description: "Also known as the Chiesa della Compagnia, this simple stone oratory holds a treasure: a unique 14th-century wooden statue called the Madonna delle Catene. The building itself is modest, but there is a quiet dignity to its plainness, and the interior feels like a secret kept by the village.",
        editorComment: "This is not a sight that announces itself. You have to seek it out, and that's part of its appeal. The wooden Madonna is remarkable—delicate and expressive in a way that feels personal rather than monumental.",
        signature: "A humble space holding centuries of devotion",
        bestTime: "Morning or late afternoon",
        crowdLevel: "Very quiet, often empty",
        duration: "10–15 minutes",
        googleRating: 4.5,
        tripadvisorRating: 4.4,
        orientation: "In the village center, near Via Colombo",
        access: "Easy access, small entrance",
        seasonalNote: "Open year-round; hours may vary, check locally."
    }
];
---

<Layout title="Sights of Riomaggiore | Cinque Terre Dispatch">
    <EditorialHero 
        title="Sights Worth<br/>Your Attention"
        subtitle="Not a catalog, but a quiet invitation to the places that define Riomaggiore—and why they matter."
        badge="Editorial Guide"
        image="/scenic_viewpoint_1765960559207.png"
    />

    <EditorialIntro 
        badge="Curated Selection"
        quote="Each sight here has been chosen not for completeness, but for character. These are the places that reveal something essential about Riomaggiore—its rhythm, its light, its relationship with the sea."
    >
        <div class="space-y-6">
            <p>
                They are presented as they deserve to be: with care, context, and a human voice.
            </p>
        </div>
        <div class="space-y-6">
            <p>
                We invite you to look beyond the surface, to notice the small details that make these places more than just photo opportunities.
            </p>
        </div>
    </EditorialIntro>

    <!-- Sights Grid -->
    <section class="py-16 container mx-auto px-4">
        <div class="space-y-32">
            {sights.map((sight, index) => (
                <article class="group cursor-pointer">
                    <!-- Image -->
                    <div class="relative aspect-[21/9] overflow-hidden rounded-xl mb-8">
                        <img 
                            src={sight.image} 
                            alt={sight.name}
                            class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105"
                        />
                        <span class="absolute top-6 left-6 bg-white/90 text-black px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wide shadow-sm">
                            {sight.category}
                        </span>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                        
                        {/* Main Content (2/3) */}
                        <div class="lg:col-span-2 space-y-8">
                            <!-- Header -->
                            <div>
                                <div class="flex items-center gap-2 mb-3">
                                    <MapPin className="w-4 h-4 text-primary" />
                                    <span class="text-sm font-medium text-muted-foreground">{sight.village}</span>
                                </div>
                                <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4 group-hover:text-primary transition-colors leading-tight">
                                    {sight.name}
                                </h2>
                            </div>

                            {/* Signature Quote (Intro) */}
                            <div class="pl-6 border-l-2 border-primary/30">
                                <p class="font-serif text-xl italic text-foreground/70 leading-relaxed">
                                    "{sight.signature}"
                                </p>
                            </div>

                            {/* Description */}
                            <div class="prose prose-lg max-w-none">
                                <p class="text-foreground/80 text-lg leading-relaxed mb-4">
                                    {sight.description}
                                </p>
                                <p class="text-muted-foreground leading-relaxed flex items-center gap-2">
                                    <Compass className="w-4 h-4 text-primary/60" />
                                    {sight.orientation}
                                </p>
                            </div>

                            <EditorNote quote={sight.editorComment} />
                        </div>

                        {/* Facts Sidebar (1/3) */}
                        <div class="lg:col-span-1">
                            <div class="sticky top-24 space-y-10">
                                <!-- Header -->
                                <div>
                                    <h3 class="font-serif text-2xl font-bold text-foreground mb-6 pb-4 border-b border-border">
                                        Essential Information
                                    </h3>
                                    
                                    <!-- Map Integration -->
                                    <div class="relative aspect-video rounded-xl overflow-hidden border border-border/50 mb-8 group/map">
                                        <img 
                                            src="https://api.mapbox.com/styles/v1/mapbox/light-v11/static/pin-l+bf2b2b(9.7376,44.099)/9.7386,44.0994,15.39,0/640x360@2x?before_layer=admin-1-boundary&access_token=pk.eyJ1IjoiZHJpZXRzY2giLCJhIjoiY21qYjAzMWxtMGJpZDNlc2RqMWN3NHdjbSJ9.k9Xvn4saiEtYhrJE8bKk7Q" 
                                            alt="Location Map"
                                            class="object-cover w-full h-full transition-transform duration-700 group-hover/map:scale-110"
                                        />
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover/map:opacity-100 transition-opacity"></div>
                                    </div>
                                </div>
                                
                                <ReviewSummary 
                                    googleRating={sight.googleRating} 
                                    tripadvisorRating={sight.tripadvisorRating} 
                                    label="Traveler Reviews"
                                />

                                <!-- Info Items -->
                                <div class="space-y-8">
                                    <SectionHeader label="Practical Details" />

                                    <div class="space-y-6">
                                        <PracticalInfoItem label="Best Time" value={sight.bestTime}>
                                            <Sunrise slot="icon" className="w-5 h-5 text-primary" />
                                        </PracticalInfoItem>

                                        <PracticalInfoItem label="Duration" value={sight.duration}>
                                            <Clock slot="icon" className="w-5 h-5 text-primary" />
                                        </PracticalInfoItem>

                                        <PracticalInfoItem label="Crowd Level" value={sight.crowdLevel}>
                                            <Users slot="icon" className="w-5 h-5 text-primary" />
                                        </PracticalInfoItem>
                                        
                                        <PracticalInfoItem label="Access" value={sight.access}>
                                            <Info slot="icon" className="w-5 h-5 text-primary" />
                                        </PracticalInfoItem>

                                        {sight.seasonalNote && (
                                            <PracticalInfoItem label="Seasonal Note" value={sight.seasonalNote}>
                                                <Sunrise slot="icon" className="w-5 h-5 text-primary" />
                                            </PracticalInfoItem>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </section>

    <ClosingNote title="A Note on Exploration">
        <p>
            These sights are not meant to be checked off a list. They are invitations to slow down, to notice, to feel. Visit them in the order that makes sense for your day, or skip the ones that don't speak to you. The best experiences in Riomaggiore are often the ones you didn't plan.
        </p>
        <p class="italic">
            — The Editors
        </p>
    </ClosingNote>

    <Footer />
</Layout>

<style>
    html {
        scroll-behavior: smooth;
    }

    .font-serif {
        letter-spacing: -0.02em;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    article {
        animation: fadeInUp 0.8s ease-out;
        animation-fill-mode: both;
    }
</style>
