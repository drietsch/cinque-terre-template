---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer';
import EditorialHero from '../components/EditorialHero.astro';
import EditorialIntro from '../components/EditorialIntro.astro';
import EditorialInterlude from '../components/EditorialInterlude.astro';
import EditorNote from '../components/EditorNote.astro';
import PracticalInfoItem from '../components/PracticalInfoItem.astro';
import ReviewSummary from '../components/ReviewSummary.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ClosingNote from '../components/ClosingNote.astro';
import { Star, MapPin, Clock, Utensils, Wine, Info, Compass, Waves, Sun, Heart } from 'lucide-react';

const restaurants = [
    {
        id: 1,
        name: "Rio Bistrot",
        category: "Refined Ligurian",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1551183053-bf91a1d81141?q=80&w=2632&auto=format&fit=crop",
        intro: "Perched above the harbor, this is where the village's culinary history meets a modern, thoughtful precision.",
        description: "Rio Bistrot is less about the view—though it is spectacular—and more about the restraint of the kitchen. They take the staples of the coast (anchovies, sea bass, local herbs) and treat them with a lightness that feels contemporary but deeply rooted. The tasting menu is a dialogue between the sea and the terraces.",
        giuliaComment: "I come here when I want to remember that our simple food can also be elegant. I always notice how they use the lemons—not just as a garnish, but as a structural element of the dish. It's best for a long, quiet dinner as the harbor lights come on.",
        signature: "Seafood that honors the sea's simplicity through modern technique",
        openingTimes: "12:30–14:30, 19:30–22:00",
        cost: "$$$",
        practicalInfo: "Reservations are essential, especially for the small balcony tables. Closed on Tuesdays.",
        googleRating: 4.6,
        tripadvisorRating: 4.5
    },
    {
        id: 2,
        name: "Dau Cila",
        category: "Seafood-focused",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1590490360182-c33d57733427?q=80&w=2574&auto=format&fit=crop",
        intro: "A waterfront classic that has remained grounded despite its enviable position at the edge of the marina.",
        description: "Dau Cila manages to feel both like a special occasion and a neighborhood staple. The focus is squarely on the catch of the day. The preparation is honest—grilled, baked in salt, or tossed with handmade pasta. It's a place that understands that when the fish is this fresh, the chef's job is to stay out of the way.",
        giuliaComment: "This is where I take friends who are visiting for the first time. There's something about sitting so close to the water while eating what was in it just hours ago. I always look for the 'Muscoli Ripieni' (stuffed mussels)—it's a dish that tastes like home.",
        signature: "The taste of the harbor, served steps from the boats",
        openingTimes: "12:00–15:00, 19:00–22:30",
        cost: "$$$",
        practicalInfo: "The outdoor tables are the draw, but the interior is cozy and full of character. Great wine list featuring local producers.",
        googleRating: 4.5,
        tripadvisorRating: 4.4
    },
    {
        id: 3,
        name: "Osteria La Torpedine",
        category: "Traditional & Intimate",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1559339352-11d035aa65de?q=80&w=2574&auto=format&fit=crop",
        intro: "Tucked away in the narrow carruggi, this osteria feels like a secret shared between the village and those who care to look.",
        description: "La Torpedine is small, warm, and intensely focused on quality. The menu is short, which is always a good sign here. They specialize in dishes that require time and patience—slow-cooked sauces, perfectly balanced pesto, and seafood that hasn't been over-complicated. It's a portrait of Ligurian hospitality.",
        giuliaComment: "I love the silence here. Away from the main street, you can actually hear the village. I usually order the seafood testaroli. It's a humble dish, but here it feels like a gift. It's the kind of place where you feel the presence of the family in every detail.",
        signature: "A quiet refuge where the food speaks louder than the location",
        openingTimes: "19:00–22:00",
        cost: "$$",
        practicalInfo: "Very limited seating. Booking a day or two in advance is highly recommended. Dinner only.",
        googleRating: 4.8,
        tripadvisorRating: 4.7
    },
    {
        id: 4,
        name: "Fuori Rotta",
        category: "Wine Bar with Small Plates",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?q=80&w=2670&auto=format&fit=crop",
        intro: "High above the bustle, this spot redefines the 'aperitivo' as a serious culinary moment.",
        description: "Fuori Rotta is where the story of the vineyards comes to life. While they serve excellent full meals, their strength lies in the pairing of local wines with carefully curated small plates. The terrace offers a view of the coastline that makes the wine taste even more of the soil it came from.",
        giuliaComment: "I come here for the sunset, but I stay for the wine list. They have bottles from tiny producers you won't find anywhere else. I love their 'tagliere'—the selection of local cheeses and cured meats is always exceptional. It's a place for conversation.",
        signature: "A celebration of the terraced vineyards in every glass",
        openingTimes: "11:00–23:00",
        cost: "$$",
        practicalInfo: "Perfect for a late afternoon drink that turns into a light dinner. The walk up is steep but worth it.",
        googleRating: 4.7,
        tripadvisorRating: 4.6
    },
    {
        id: 5,
        name: "Il Pescato Cucinato",
        category: "Street Food (Fried Fish)",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1565689157206-0fddef7589a2?q=80&w=2670&auto=format&fit=crop",
        intro: "The ultimate expression of the village's daily rhythm—fast, fresh, and unpretentious.",
        description: "There are no tables here, just a counter and a fryer. This is the 'fritto misto' in its purest form: calamari, shrimp, and the legendary local anchovies, lightly battered and served in a paper cone. It's the meal of the fisherman and the traveler alike, meant to be eaten while walking or sitting on the harbor rocks.",
        giuliaComment: "This is my 'guilty' pleasure, though there's nothing to feel guilty about. The fish is often fresher here than in the sit-down restaurants. I always get the cone with just anchovies. It's the taste of Riomaggiore in a single bite.",
        signature: "The village's favorite snack, served hot and salty in a cone",
        openingTimes: "11:30–20:00",
        cost: "$",
        practicalInfo: "Expect a queue during peak hours, but it moves fast. Take your cone down to the harbor for the best experience.",
        googleRating: 4.6,
        tripadvisorRating: 4.5
    },
    {
        id: 6,
        name: "Da Dulìn",
        category: "Traditional Ligurian",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1534308983496-4fabb1a015ee?q=80&w=2676&auto=format&fit=crop",
        intro: "A place where the recipes feel like they've been handed down through generations without losing their spark.",
        description: "Da Dulìn is known for its consistency and its heart. While they serve great pizza, the real treasures are the Ligurian classics. Their lasagna al pesto is legendary—rich, fragrant, and exactly how it should be. It's a restaurant that doesn't try to be anything other than what it is: a reliable, delicious kitchen.",
        giuliaComment: "When I want comfort food, I come here. The atmosphere is always lively but never chaotic. I notice how the locals interact with the staff—it's a community hub. Don't skip the seafood salad; it's simple but the quality of the oil makes it shine.",
        signature: "Honest cooking that feels like a Sunday lunch at a local home",
        openingTimes: "12:00–14:30, 18:30–22:30",
        cost: "$$",
        practicalInfo: "Great for families. The location is slightly away from the main tourist flow, making it a bit more relaxed.",
        googleRating: 4.4,
        tripadvisorRating: 4.3
    },
    {
        id: 7,
        name: "Trattoria La Lampara",
        category: "Home-style Cooking",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1467003909585-2f8a72700288?q=80&w=2574&auto=format&fit=crop",
        intro: "A warm, bustling trattoria that captures the unhurried spirit of a Ligurian kitchen.",
        description: "La Lampara is where you go for the dishes that define the region's 'cucina povera' (peasant cooking). Think trofie al pesto, pansotti with walnut sauce, and stuffed vegetables. The flavors are bold and authentic, and the service is characterized by a genuine, no-nonsense warmth.",
        giuliaComment: "I love the energy here. It's loud, it's busy, and it smells incredible. I always look for the daily specials—that's where the real magic happens. If they have the Fassona ragu, get it. It's a reminder that we have a connection to the inland hills too.",
        signature: "A vibrant celebration of Liguria's most beloved flavors",
        openingTimes: "12:00–15:00, 19:00–22:00",
        cost: "$$",
        practicalInfo: "Very popular with locals for lunch. Arrive early or be prepared for a short wait. Closed on Wednesdays.",
        googleRating: 4.5,
        tripadvisorRating: 4.4
    },
    {
        id: 8,
        name: "Il Grottino",
        category: "Seafood-focused",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1551183053-bf91a1d81141?q=80&w=2632&auto=format&fit=crop",
        intro: "Located in the heart of the village, this spot offers a reliable and welcoming window into the local catch.",
        description: "Il Grottino is a place of balance. It's central but doesn't feel like a tourist trap. The seafood is the star, prepared with traditional methods but presented with a bit of flair. It's the kind of place where you can have a quick pasta or a multi-course seafood feast and feel equally well-treated.",
        giuliaComment: "I appreciate the consistency here. You know exactly what you're going to get: fresh fish and a warm smile. I often come here for a quick lunch of spaghetti allo scoglio. The portions are generous and the flavors are clean.",
        signature: "A welcoming heart in the center of the village",
        openingTimes: "12:00–15:00, 19:00–22:30",
        cost: "$$",
        practicalInfo: "Good for groups. The atmosphere is casual and friendly. Right on the main street.",
        googleRating: 4.5,
        tripadvisorRating: 4.4
    },
    {
        id: 9,
        name: "Trattoria Via dell'Amore",
        category: "Traditional & Scenic",
        village: "Riomaggiore",
        image: "https://images.unsplash.com/photo-1590490360182-c33d57733427?q=80&w=2574&auto=format&fit=crop",
        intro: "A restaurant that carries the name of the famous path and the weight of local tradition.",
        description: "This trattoria is a testament to the endurance of local flavors. The menu is a collection of Riomaggiore's greatest hits, served in a setting that feels timeless. They are particularly proud of their homemade pasta and their use of local olive oil, which they treat as a primary ingredient rather than a condiment.",
        giuliaComment: "The name might sound touristy, but the food is anything but. I've had some of the best gnocchetti here. I notice the care they take with the bread—it's always fresh and perfect for 'scarpetta' (mopping up the sauce).",
        signature: "A place where the name is a promise of local heritage",
        openingTimes: "12:00–14:30, 19:00–22:00",
        cost: "$$",
        practicalInfo: "The terrace is lovely in the summer. It's a bit of a climb from the harbor, which keeps the crowds slightly thinner.",
        googleRating: 4.6,
        tripadvisorRating: 4.5
    }
];
---

<Layout title="The Culinary Story of Riomaggiore | Cinque Terre Dispatch">
    <EditorialHero 
        title="The Story of<br/>the Table"
        subtitle="In Riomaggiore, food is not an attraction. It is a rhythm, a memory, and a response to a vertical world."
        badge="Culinary Narrative"
        image="https://images.unsplash.com/photo-1499678329028-101435549a4e?q=80&w=2670&auto=format&fit=crop"
    />

    <EditorialIntro 
        badge="The Culinary Story"
        quote="To eat in Riomaggiore is to understand scarcity. For centuries, this village had no flat land for cattle, no wide fields for grain. It had only the verticality of the cliffs and the depth of the sea."
    >
        <div class="space-y-6">
            <p>
                The story begins in the <strong>terraces</strong>. Every inch of soil was earned, carved out of the rock to plant grapevines and olive trees. This is why wine here is not just a drink; it is the village's primary currency of labor. The Sciacchetrà you sip today is the same liquid gold that has sustained these families through generations of isolation.
            </p>
            <p>
                Then there is the <strong>sea</strong>. Because the village was poor and the work was hard, the food became simple. Fish is served with little more than a squeeze of lemon and a drizzle of the oil pressed from those hillside groves. There is no need for heavy sauces when the catch was in the water three hours ago.
            </p>
        </div>
        <div class="space-y-6">
            <p>
                You will notice that <strong>menus are short</strong>. This is not a lack of choice, but a commitment to the day. If the sea was rough, there is no sea bass. If the 'orto' (the garden) is between seasons, the vegetables will change. We eat what the land and sea allow, following a rhythm tied to light and weather.
            </p>
            <p>
                Meals here follow the <strong>rhythm of work</strong>. A quick cone of fried fish at midday to keep moving, and a long, slow dinner as the sun dips behind the village—a time to reclaim the day from the crowds. To eat well here is to be receptive to these rhythms, to stop looking for variety and start looking for place.
            </p>
        </div>
    </EditorialIntro>

    <!-- Transition Section -->
    <section class="py-20 bg-secondary/20 border-y border-border/40">
        <div class="container mx-auto px-4 text-center">
            <h2 class="font-serif text-4xl md:text-5xl font-bold text-foreground mb-6">
                Where this story is still cooked
            </h2>
            <p class="text-xl text-muted-foreground max-w-2xl mx-auto font-light leading-relaxed">
                The following places are not a leaderboard. They are a collection of different facets of our culinary culture—each one a portrait of how Riomaggiore feeds itself and its guests.
            </p>
        </div>
    </section>

    <!-- Restaurants Collection -->
    <section class="py-24 container mx-auto px-4">
        <div class="space-y-32">
            {restaurants.map((restaurant, index) => (
                <div class="space-y-16">
                    {/* Editorial Interludes */}
                    {index === 3 && (
                        <EditorialInterlude 
                            title="The Logic of the Short Menu"
                            quote="In many places, a long menu is a sign of abundance. In Riomaggiore, it is often a sign of frozen storage. Look for the places that offer only four or five starters and mains. It means the chef was at the harbor this morning, and the 'orto' yesterday. Variety is the enemy of freshness in a village this small."
                            type="primary"
                            align="left"
                        >
                            <Utensils slot="icon" className="w-96 h-96" />
                        </EditorialInterlude>
                    )}

                    {index === 6 && (
                        <EditorialInterlude 
                            title="The Bread and the Oil"
                            quote="Before you order, look at the bread and the oil on the table. In Liguria, these are not fillers. The oil should be green-gold and smell of the hills. The bread should be simple, a vessel for that oil. If a restaurant gets these two right, you can trust them with the rest of the meal."
                            type="secondary"
                            align="right"
                        >
                            <Wine slot="icon" className="w-96 h-96" />
                        </EditorialInterlude>
                    )}

                    <article class="group cursor-pointer">
                        <!-- Image -->
                        <div class="relative aspect-[21/9] overflow-hidden rounded-xl mb-8">
                            <img 
                                src={restaurant.image} 
                                alt={restaurant.name}
                                class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105"
                            />
                            <span class="absolute top-6 left-6 bg-white/90 text-black px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wide shadow-sm">
                                {restaurant.category}
                            </span>
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                            
                            {/* Main Content (2/3) */}
                            <div class="lg:col-span-2 space-y-8">
                                <!-- Header -->
                                <div>
                                    <div class="flex items-center gap-2 mb-3">
                                        <MapPin className="w-4 h-4 text-primary" />
                                        <span class="text-sm font-medium text-muted-foreground">{restaurant.village}</span>
                                    </div>
                                    <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4 group-hover:text-primary transition-colors leading-tight">
                                        {restaurant.name}
                                    </h2>
                                </div>

                                {/* Signature Quote (Intro) */}
                                <div class="pl-6 border-l-2 border-primary/30">
                                    <p class="font-serif text-xl italic text-foreground/70 leading-relaxed">
                                        "{restaurant.intro}"
                                    </p>
                                </div>

                                {/* Description */}
                                <div class="prose prose-lg max-w-none">
                                    <p class="text-foreground/80 text-lg leading-relaxed mb-4">
                                        {restaurant.description}
                                    </p>
                                    <p class="text-muted-foreground leading-relaxed flex items-center gap-2">
                                        <Heart className="w-4 h-4 text-primary/60" />
                                        {restaurant.signature}
                                    </p>
                                </div>

                                <EditorNote quote={restaurant.giuliaComment} />
                            </div>

                            {/* Facts Sidebar (1/3) */}
                            <div class="lg:col-span-1">
                                <div class="sticky top-24 space-y-10">
                                    <!-- Header -->
                                    <div>
                                        <h3 class="font-serif text-2xl font-bold text-foreground mb-6 pb-4 border-b border-border">
                                            Essential Information
                                        </h3>
                                        
                                        <!-- Map Integration -->
                                        <div class="relative aspect-video rounded-xl overflow-hidden border border-border/50 mb-8 group/map">
                                            <img 
                                                src="https://api.mapbox.com/styles/v1/mapbox/light-v11/static/pin-l+bf2b2b(9.7376,44.099)/9.7386,44.0994,15.39,0/640x360@2x?before_layer=admin-1-boundary&access_token=pk.eyJ1IjoiZHJpZXRzY2giLCJhIjoiY21qYjAzMWxtMGJpZDNlc2RqMWN3NHdjbSJ9.k9Xvn4saiEtYhrJE8bKk7Q" 
                                                alt="Location Map"
                                                class="object-cover w-full h-full transition-transform duration-700 group-hover/map:scale-110"
                                            />
                                            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover/map:opacity-100 transition-opacity"></div>
                                        </div>
                                    </div>
                                    
                                    <ReviewSummary 
                                        googleRating={restaurant.googleRating} 
                                        tripadvisorRating={restaurant.tripadvisorRating} 
                                    />

                                    <!-- Info Items -->
                                    <div class="space-y-8">
                                        <SectionHeader label="Practical Details" />

                                        <div class="space-y-6">
                                            <PracticalInfoItem label="Price Range" value={restaurant.category}>
                                                <span slot="icon" class="text-primary font-bold text-lg">{restaurant.cost}</span>
                                            </PracticalInfoItem>

                                            <PracticalInfoItem label="Opening Hours" value={restaurant.openingTimes}>
                                                <Clock slot="icon" className="w-5 h-5 text-primary" />
                                            </PracticalInfoItem>
                                            
                                            <PracticalInfoItem label="Notes" value={restaurant.practicalInfo}>
                                                <Info slot="icon" className="w-5 h-5 text-primary" />
                                            </PracticalInfoItem>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>
                </div>
            ))}
        </div>
    </section>

    <ClosingNote title="The Best Meal is a Matter of Mood">
        <Waves slot="background" className="w-full h-full scale-150" />
        <p>
            In the end, eating well in Riomaggiore is less about finding the "perfect" restaurant and more about matching your meal to your spirit. 
        </p>
        <p>
            Some days require the quiet of a hidden osteria; others, the salt-spray energy of the harbor rocks with a paper cone of fish. Sometimes, all you need is a glass of Sciacchetrà and the sound of the sea.
        </p>
        <p>
            Slow down. Notice the light. Listen to the village. The table will find you.
        </p>
        <div slot="actions" class="flex flex-wrap justify-center gap-6">
            <a href="/itinerary" class="px-8 py-4 rounded-full bg-primary text-white font-bold text-sm uppercase tracking-widest hover:bg-primary/90 transition-colors">
                Plan Your Day
            </a>
            <a href="/village" class="px-8 py-4 rounded-full bg-white/10 backdrop-blur-sm text-white font-bold text-sm uppercase tracking-widest hover:bg-white/20 transition-colors">
                Explore the Village
            </a>
        </div>
    </ClosingNote>

    <Footer />
</Layout>

<style>
    html {
        scroll-behavior: smooth;
    }

    .font-serif {
        letter-spacing: -0.02em;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    article {
        animation: fadeInUp 0.8s ease-out;
        animation-fill-mode: both;
    }
</style>
