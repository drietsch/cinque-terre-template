---
import { Input } from '@/components/ui/input';
import { Button } from '@/components/ui/button';
import { getPageContent } from '../lib/content';

interface Props {
    lang?: 'en' | 'it';
}

const { lang = 'en' } = Astro.props;
const page = getPageContent('home', lang);
const section = page.newsletter;
---

<section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-primary z-0"></div>
    <div class="absolute inset-0 bg-cover bg-center opacity-20 mix-blend-overlay z-0" style={`background-image: url('${section.backgroundImage}')`}></div>

    <div class="container mx-auto px-4 relative z-10 text-center text-primary-foreground">
        <h2 class="font-serif text-3xl md:text-5xl font-bold mb-4">{section.title}</h2>
        <p class="text-lg md:text-xl mb-8 max-w-xl mx-auto opacity-90">
            {section.subtitle}
        </p>

        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <Input
                type="email"
                placeholder={section.placeholder}
                className="h-12 bg-background text-foreground border-none"
            />
            <Button size="lg" variant="secondary" className="h-12 px-8 font-bold">{section.buttonText}</Button>
        </form>
        <p class="text-sm mt-4 opacity-70">{section.socialProof}</p>
    </div>
</section>

<script>
    const form = document.querySelector('form');
    if (form) {
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Thanks for subscribing!');
        });
    }
</script>
