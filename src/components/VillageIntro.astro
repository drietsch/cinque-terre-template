---
import { Card, CardHeader, CardTitle, CardContent } from './ui/card';
import { Badge } from './ui/badge';
import { Sun, Footprints, History, Star } from 'lucide-react';
import { getVillageIntroStories, getVillageEssentials, getPageContent } from '../lib/content';

interface Props {
    lang?: 'en' | 'it';
}

const { lang = 'en' } = Astro.props;
const stories = getVillageIntroStories(lang);
const essentials = getVillageEssentials(lang);
const page = getPageContent('village', lang);

const leadStory = stories[0];
const otherStories = stories.slice(1);
const filters = page.villageIntro.filters;
---

<section class="py-16 container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {/* Lead Story */}
        <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-1 gap-8 mb-8 group cursor-pointer">

             <div class="flex flex-col justify-center">
                <div class="flex items-center gap-2 mb-4">
                    <span class="bg-primary/10 text-primary text-xs font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wide">
                        {leadStory.category}
                    </span>
                    <span class="text-sm text-muted-foreground">{leadStory.readTime}</span>
                </div>
                <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4 group-hover:text-primary transition-colors leading-tight">
                    {leadStory.title}
                </h3>
                <p class="text-muted-foreground text-lg mb-6 line-clamp-3">
                    {leadStory.excerpt}
                </p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-secondary overflow-hidden">
                        <img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${leadStory.author}`} alt={leadStory.author} />
                    </div>
                    <div class="text-sm">
                        <p class="font-medium text-foreground">{leadStory.author} – {page.villageIntro.authorSuffix}</p>
                        <p class="text-muted-foreground">{leadStory.date}</p>
                    </div>
                </div>
             </div>
        </div>

        <div class="lg:col-span-3 mb-16">
            <Card className="bg-white/80 dark:bg-card/80 backdrop-blur-md border-primary/10 shadow-xl overflow-hidden relative">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary/40 via-primary to-primary/40"></div>
                <CardHeader className="pb-8 pt-8 text-center space-y-2">
                    <div class="mx-auto w-fit px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-2">
                        {essentials.badge}
                    </div>
                    <CardTitle className="font-serif text-3xl md:text-4xl text-foreground">{essentials.title}</CardTitle>
                    <p class="text-muted-foreground font-serif italic text-lg">{essentials.subtitle}</p>
                </CardHeader>
                
                <CardContent className="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 relative p-8">
                    {/* Vertical Dividers for Desktop */}
                    <div class="hidden md:block absolute top-8 bottom-8 left-1/3 w-px bg-border/50"></div>
                    <div class="hidden md:block absolute top-8 bottom-8 right-1/3 w-px bg-border/50"></div>

                    {essentials.columns.map((column: { icon: string; title: string; items: { label: string; value: string }[] }, index: number) => (
                        <div class="space-y-6 relative z-10 px-4 flex flex-col items-center text-center">
                            <div class="flex flex-col items-center gap-3 mb-4">
                                <div class={`p-2 rounded-lg ${index === 0 ? 'bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400' : index === 1 ? 'bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400' : 'bg-purple-100 text-purple-600 dark:bg-purple-900/30 dark:text-purple-400'}`}>
                                    {column.icon === 'Sun' && <Sun className="w-5 h-5" />}
                                    {column.icon === 'Footprints' && <Footprints className="w-5 h-5" />}
                                    {column.icon === 'History' && <History className="w-5 h-5" />}
                                </div>
                                <h4 class="font-bold text-sm uppercase tracking-wider text-foreground">{column.title}</h4>
                            </div>

                            <ul class="space-y-4 text-sm w-full">
                                {column.items.map((item: { label: string; value: string }) => (
                                    <li class="group flex flex-col items-center">
                                        <span class="text-muted-foreground mb-1 uppercase tracking-wider text-xs">{item.label}</span>
                                        <div class="font-medium text-base">{item.value}</div>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </CardContent>
            </Card>
        </div>

        {/* Other Stories */}
        {otherStories.map(story => (
            <div class="group cursor-pointer flex flex-col h-full">
                <div class="relative aspect-[3/2] overflow-hidden rounded-xl mb-4">
                    <img src={story.image} alt={story.title} class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105" />
                    <span class="absolute top-3 left-3 bg-white/90 text-black px-2 py-0.5 rounded-md text-xs font-bold uppercase tracking-wide shadow-sm">
                        {story.category}
                    </span>
                </div>
                <h3 class="font-serif text-xl font-bold mb-2 group-hover:text-primary transition-colors leading-snug flex-grow">
                    {story.title}
                </h3>
                <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                    {story.excerpt}
                </p>
                <div class="flex items-center gap-2 mt-auto">
                    <div class="w-6 h-6 rounded-full bg-secondary overflow-hidden">
                        <img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${story.author}`} alt={story.author} />
                    </div>
                    <div class="text-xs text-muted-foreground">
                        <span class="font-medium text-foreground">{story.author}</span> • {story.date}
                    </div>
                </div>
            </div>
        ))}
    </div>
    
    <div class="mt-12 text-center">
        <button class="px-8 py-3 rounded-full border border-border hover:bg-secondary transition-colors font-medium">
            {page.villageIntro.loadMoreButton}
        </button>
    </div>
</section>
