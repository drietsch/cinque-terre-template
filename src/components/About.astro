---
import { getPageContent, getTeam } from '../lib/content';

interface Props {
    lang?: 'en' | 'it';
}

const { lang = 'en' } = Astro.props;
const page = getPageContent('home', lang);
const section = page.about;
const team = getTeam(lang);
---

<section class="py-24 container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-24">
        <div class="w-full md:w-1/2 relative">
            <div class="aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl">
                <img src={section.image} alt={section.imageAlt} class="w-full h-full object-cover" />
            </div>
            <div class="absolute -bottom-6 -right-6 w-2/3 aspect-square bg-secondary rounded-2xl -z-10"></div>
        </div>

        <div class="w-full md:w-1/2">
            <span class="text-sm font-semibold text-primary uppercase tracking-wider">{section.badge}</span>
            <h2 class="font-serif text-4xl md:text-5xl font-bold mt-4 mb-6 leading-tight">{section.title}</h2>
            {section.description.map((paragraph: string) => (
                <p class="text-lg text-muted-foreground mb-6">{paragraph}</p>
            ))}

            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-gray-200 overflow-hidden">
                    <img src={team.editorInChief.avatar} alt={team.editorInChief.name} />
                </div>
                <div>
                    <p class="font-bold text-foreground">{team.editorInChief.name}</p>
                    <p class="text-sm text-muted-foreground">{team.editorInChief.title}</p>
                </div>
            </div>
        </div>
    </div>
</section>
