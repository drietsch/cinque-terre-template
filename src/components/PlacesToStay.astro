---
import { getStays, getPageContent, getCommon } from '../lib/content';

interface Props {
    lang?: 'en' | 'it';
}

const { lang = 'en' } = Astro.props;
const stays = getStays(lang);
const page = getPageContent('home', lang);
const section = page.placesToStay;
const common = getCommon(lang);
---

<section class="py-16 container mx-auto px-4">
    <div class="flex items-end justify-between mb-12">
        <div>
            <span class="text-sm font-semibold text-primary uppercase tracking-wider">{section.badge}</span>
            <h2 class="font-serif text-3xl md:text-4xl font-bold mt-2">{section.title}</h2>
        </div>
        <a href="#" class="hidden md:inline-flex items-center text-sm font-medium hover:text-primary transition-colors">
            {common.buttons.seeAllStays} <span class="ml-1">→</span>
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {stays.map(stay => (
            <div class="group cursor-pointer">
                <div class="relative aspect-[4/3] overflow-hidden rounded-xl mb-4 shadow-sm">
                    <img src={stay.image} alt={stay.name} class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105" />
                    <div class="absolute top-3 left-3">
                        <span class="bg-white/90 text-black text-xs font-bold px-2.5 py-1 rounded-md shadow-sm uppercase tracking-wide">
                            {stay.village}
                        </span>
                    </div>
                    <div class="absolute top-3 right-3">
                        <span class="bg-black/60 backdrop-blur-md text-white text-xs font-bold px-2 py-1 rounded-md border border-white/10">
                            {stay.price}
                        </span>
                    </div>
                </div>
                <h3 class="font-serif text-xl font-bold mb-1 group-hover:text-primary transition-colors">
                    {stay.name}
                </h3>
                <p class="text-muted-foreground text-sm">
                    {stay.special}
                </p>
            </div>
        ))}
    </div>
    
    <div class="mt-8 text-center md:hidden">
        <a href="#" class="inline-flex items-center text-sm font-medium hover:text-primary transition-colors">
            {common.buttons.seeAllStays} <span class="ml-1">→</span>
        </a>
    </div>
</section>
