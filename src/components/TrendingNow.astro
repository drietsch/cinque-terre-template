---
import { getTrendingStories, getPageContent } from '../lib/content';

interface Props {
    lang?: 'en' | 'it';
}

const { lang = 'en' } = Astro.props;
const trendingStories = getTrendingStories(lang);
const page = getPageContent('home', lang);
const section = page.trendingNow;

const leadStory = trendingStories[0];
const secondaryStories = trendingStories.slice(1);
---

<section class="py-16 container mx-auto px-4">
    <h2 class="font-serif text-3xl md:text-4xl font-bold mb-8">{section.title}</h2>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {/* Lead Story */}
        <div class="lg:col-span-2 group cursor-pointer">
            <div class="relative aspect-[16/9] overflow-hidden rounded-xl mb-4">
                <img src={leadStory.image} alt={leadStory.title} class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105" />
                <span class="absolute top-4 left-4 bg-white/90 text-black px-2.5 py-0.5 rounded-full text-xs font-semibold uppercase tracking-wide shadow-sm">
                    {leadStory.category}
                </span>
            </div>
            <h3 class="font-serif text-2xl md:text-3xl font-bold mb-3 group-hover:text-primary transition-colors leading-tight">
                {leadStory.title}
            </h3>
            <div class="flex items-center justify-between mt-4">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-secondary overflow-hidden">
                        <img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${leadStory.author}`} alt={leadStory.author} />
                    </div>
                    <span class="text-sm font-medium text-foreground">{leadStory.author}</span>
                </div>
                <div class="flex items-center text-sm text-muted-foreground gap-3">
                    <span>{leadStory.date}</span>
                    <span class="w-1 h-1 bg-muted-foreground rounded-full"></span>
                    <span>{leadStory.readTime}</span>
                </div>
            </div>
        </div>

        {/* Secondary Stories */}
        <div class="flex flex-col gap-6">
            {secondaryStories.map(story => (
                <div class="flex gap-4 group cursor-pointer items-start">
                    <div class="relative w-24 h-24 flex-shrink-0 overflow-hidden rounded-lg">
                        <img src={story.image} alt={story.title} class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105" />
                    </div>
                    <div class="flex flex-col justify-center flex-1">
                        <span class="text-xs font-semibold text-primary mb-1 uppercase tracking-wide">{story.category}</span>
                        <h4 class="font-serif text-lg font-bold mb-1 group-hover:text-primary transition-colors leading-snug line-clamp-2">
                            {story.title}
                        </h4>
                        <div class="flex items-center justify-between mt-1">
                            <div class="flex items-center gap-2">
                                <div class="w-5 h-5 rounded-full bg-secondary overflow-hidden">
                                    <img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${story.author}`} alt={story.author} />
                                </div>
                                <span class="text-xs font-medium text-muted-foreground">{story.author}</span>
                            </div>
                            <div class="flex items-center text-xs text-muted-foreground gap-2">
                                <span>{story.date}</span>
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
