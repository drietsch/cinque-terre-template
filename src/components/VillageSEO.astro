---
import { Card, CardContent, CardHeader, CardTitle } from './ui/card';
import { getVillageAbout, getVillageInsiderSecrets, getVillageFAQs, getPageContent } from '../lib/content';

interface Props {
    lang?: 'en' | 'it';
}

const { lang = 'en' } = Astro.props;
const aboutItems = getVillageAbout(lang);
const insiderSecrets = getVillageInsiderSecrets(lang);
const faqs = getVillageFAQs(lang);
const page = getPageContent('village', lang);
const seoContent = page.villageSEO;
---

<section class="py-24 container mx-auto px-4">
    <div class="max-w-5xl mx-auto space-y-16">

        {/* Header */}
        <div class="text-center space-y-4">
            <div class="inline-flex items-center justify-center px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest">
                {seoContent.header.badge}
            </div>
            <h2 class="font-serif text-4xl md:text-5xl text-foreground">{seoContent.header.title}</h2>
            <p class="text-muted-foreground text-lg max-w-2xl mx-auto font-serif italic">
                {seoContent.header.subtitle}
            </p>
        </div>

        {/* About Section */}
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start py-12 border-t border-border/40">
            <div class="md:col-span-4 space-y-4">
                <h3 class="font-serif text-3xl text-foreground leading-tight">{seoContent.aboutSection.title}</h3>
                <p class="text-muted-foreground font-serif italic">
                    {seoContent.aboutSection.subtitle}
                </p>
            </div>
            <div class="md:col-span-8 space-y-12">
                {aboutItems.map((item: { number: string; title: string; description: string }) => (
                    <div class="group">
                        <div class="flex items-start gap-6">
                            <span class="font-serif text-6xl text-primary/10 group-hover:text-primary/20 transition-colors leading-none select-none">{item.number}</span>
                            <div class="space-y-3">
                                <h4 class="font-serif text-xl text-foreground group-hover:text-primary transition-colors">{item.title}</h4>
                                <p class="text-muted-foreground leading-relaxed text-lg">
                                    {item.description}
                                </p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        {/* Insider Secrets Section */}
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start py-12 border-y border-border/40">
            <div class="md:col-span-4 space-y-4">
                <h3 class="font-serif text-3xl text-foreground leading-tight">{seoContent.insiderSecretsSection.title}</h3>
                <p class="text-muted-foreground font-serif italic">
                    {seoContent.insiderSecretsSection.subtitle}
                </p>
            </div>
            <div class="md:col-span-8 space-y-12">
                {insiderSecrets.map((item: { number: string; title: string; quote: string }) => (
                    <div class="group">
                        <div class="flex items-start gap-6">
                            <span class="font-serif text-6xl text-primary/10 group-hover:text-primary/20 transition-colors leading-none select-none">{item.number}</span>
                            <div class="space-y-3">
                                <h4 class="font-serif text-xl text-foreground group-hover:text-primary transition-colors">{item.title}</h4>
                                <p class="text-muted-foreground leading-relaxed text-lg italic">
                                    "{item.quote}"
                                </p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <hr class="border-border/40" />

        {/* FAQ Section */}
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start py-12">
            <div class="md:col-span-4 space-y-4">
                <h3 class="font-serif text-3xl text-foreground leading-tight">{seoContent.faqSection.title}</h3>
                <p class="text-muted-foreground font-serif italic">
                    {seoContent.faqSection.subtitle}
                </p>
            </div>
            <div class="md:col-span-8 space-y-12">
                {faqs.map((item: { number: string; question: string; answer: string }) => (
                    <div class="group">
                        <div class="flex items-start gap-6">
                            <span class="font-serif text-6xl text-primary/10 group-hover:text-primary/20 transition-colors leading-none select-none">{item.number}</span>
                            <div class="space-y-3">
                                <h4 class="font-serif text-xl text-foreground group-hover:text-primary transition-colors">{item.question}</h4>
                                <p class="text-muted-foreground leading-relaxed text-lg">
                                    {item.answer}
                                </p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

    </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": "Riomaggiore",
  "description": "Riomaggiore is a historic coastal village in Liguria, Italy, and the easternmost of the five villages of the Cinque Terre.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Riomaggiore",
    "addressRegion": "Liguria",
    "addressCountry": "Italy"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 44.0985,
    "longitude": 9.7386
  },
  "touristType": [
    "HistoricSite",
    "NatureReserve"
  ],
  "publicAccess": true,
  "isAccessibleForFree": true
}
</script>
